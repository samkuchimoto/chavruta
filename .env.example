# ============================================================
# Chavruta v1 — environment variables
# Copy to .env.local and fill in values. Never commit .env.local.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Project Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, bypasses RLS.
# Used for: matching logic, session creation, queue management.
# Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Groq ─────────────────────────────────────────────────────
# console.groq.com → API Keys
GROQ_API_KEY=your-groq-api-key

# ── Nomic (embeddings) ────────────────────────────────────────
# atlas.nomic.ai → API Keys
# Used for: embedding what_i_know + what_i_want into pgvector
NOMIC_API_KEY=your-nomic-api-key

# ── Stripe ───────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Note: no client-side Stripe.js used — checkout is a server-side redirect.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY is not needed for this setup.

# Webhook secret — generated when you create the webhook endpoint
# in Stripe dashboard (or via: stripe listen --forward-to localhost:3000/api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=whsec_...

# The Price ID for the €15/month subscription
# Create in Stripe dashboard: Products → Add product → Recurring, €15/month
STRIPE_PRICE_ID=price_...

# ── Gmail (OAuth2 for transactional email) ────────────────────
# Setup steps:
#   1. console.cloud.google.com → New project → Enable Gmail API
#   2. OAuth consent screen → External → add your Gmail as test user
#   3. Credentials → OAuth 2.0 Client ID → Desktop app
#   4. Use OAuth Playground (developers.google.com/oauthplayground)
#      with scope: https://mail.google.com/
#      to generate a refresh token for your account
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token

# The Gmail address you authorised above
GMAIL_FROM_ADDRESS=chavruta@yourdomain.com

# ── App ──────────────────────────────────────────────────────
# No trailing slash. Used for: email links, Stripe redirect URLs.
# Local: http://localhost:3000
# Production: https://chavruta.vercel.app (or your custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Cron ─────────────────────────────────────────────────────
# Any random string — protects /api/cron/reminders from unauthorized calls.
# Vercel injects this automatically as a Bearer token when the cron fires.
# Generate one with: openssl rand -hex 32
CRON_SECRET=

# ── Zadera (future — leave blank until API contract is ready) ──
# When wired up, the container selects the Zadera matching adapter.
ZADERA_API_KEY=
ZADERA_API_URL=
